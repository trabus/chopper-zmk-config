#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define DEFAULT 0
#define LOWER   1

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // =========================================================================
            // DEFAULT LAYOUT LAYER (52 Alpha/Nav Keys + 2 Encoder Buttons = 54 Bindings)
            // =========================================================================
            bindings = <
    // Physical Row 1 (14 keys)
    &kp ESC   &kp Q    &kp W    &kp E    &kp R    &kp T    &kp Y    &kp U    &kp I    &kp O    &kp P    &kp LBKT  &kp RBKT  &kp BSPC
    // Physical Row 2 (14 keys)
    &kp TAB   &kp A    &kp S    &kp D    &kp F    &kp G    &kp H    &kp J    &kp K    &kp L    &kp SEMI &kp SQT   &kp NUHS  &kp RET
    // Physical Row 3 (16 keys - framed by left Mute and right Arrow)
    &kp MUTE  &kp LSHFT &kp Z   &kp X    &kp C    &kp V    &kp B    &kp N    &kp M    &kp COMMA &kp DOT &kp FSLH  &kp RSHFT &kp UP    &kp DEL   &kp RIGHT
    // Physical Row 4 (8 keys - Standalone Clean Thumb Modifiers)
                       &kp LCTRL &kp LCMD &mo LOWER         &kp SPACE &kp ENTER &mo LOWER &kp RCMD  &kp LALT
            >;

            // Encoder Left: Volume Control | Encoder Right: Page Nav Scrolling
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        lower_layer {
            // =========================================================================
            // LOWER UTILITIES LAYER (Activated by holding down either Layer thumb key)
            // =========================================================================
            bindings = <
    // Number row generation layer (14 keys)
    &kp GRAVE &kp N1   &kp N2   &kp N3   &kp N4   &kp N5   &kp N6   &kp N7   &kp N8   &kp N9   &kp N0   &kp MINUS &kp EQUAL &none
    // RGB strip control tools (14 keys)
    &rgb_ug RGB_TOG &rgb_ug RGB_HUI &rgb_ug RGB_SAI &rgb_ug RGB_BRI &rgb_ug RGB_EFF &none &none &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &none &none
    // Row 3 (16 keys)
    &none     &none     &rgb_ug RGB_HUD &rgb_ug RGB_SAD &rgb_ug RGB_BRD &rgb_ug RGB_EFR &none &none &none &none     &none     &none     &none     &none     &none     &none
    // Row 4 (8 keys)
                                 &none    &none    &trans                     &trans    &none     &none    &none     &none
            >;

            // Encoder Left: Cycle RGB Brightness | Encoder Right: Cycle RGB Effects
            sensor-bindings = <&inc_dec_kp RGB_BRI RGB_BRD &inc_dec_kp RGB_EFF RGB_EFR>;
        };
    };
};
