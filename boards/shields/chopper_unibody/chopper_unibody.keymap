#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // =========================================================================
            // DEFAULT LAYOUT LAYER (50 Alpha/Nav Keys + 2 Encoder Buttons = 52 Bindings)
            // =========================================================================
            bindings = <
                // Physical Row 1 (14 keys)
                &kp ESC   &kp Q    &kp W    &kp E    &kp R    &kp T    &kp Y    &kp U    &kp I    &kp O    &kp P    &kp LBKT  &kp RBKT  &kp BSPC
                // Physical Row 2 (14 keys)
                &kp TAB   &kp A    &kp S    &kp D    &kp F    &kp G    &kp H    &kp J    &kp K    &kp L    &kp SEMI &kp SQT   &kp NON_US_HASH &kp RET
                // Physical Row 3 (16 keys - framed by left Mute and right Arrow)
                &kp C_MUTE  &kp LSHFT &kp Z   &kp X    &kp C    &kp V    &kp B    &kp N    &kp M    &kp COMMA &kp DOT &kp FSLH  &kp RSHFT &kp UP    &kp DEL   &kp RIGHT
                // Physical Row 4 (8 keys - Standalone Clean Thumb Modifiers)
                &kp LCTRL &kp LCMD &none             &kp SPACE &kp ENTER &none     &kp RCMD  &kp LALT
            >;

            // Encoder Left: Volume Control | Encoder Right: Page Nav Scrolling
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };
    };
};
